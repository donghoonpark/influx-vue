{
  "name": "influx-vue",
  "version": "0.3.1",
  "description": "A Vue 3 + TypeScript workbench for exploring InfluxDB buckets, schema, Flux queries, and visualizations.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donghoonpark/influx-vue.git"
  },
  "homepage": "https://github.com/donghoonpark/influx-vue#readme",
  "bugs": {
    "url": "https://github.com/donghoonpark/influx-vue/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/influx-vue.umd.cjs",
  "module": "./dist/influx-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/influx-vue.js",
      "require": "./dist/influx-vue.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/influx-vue.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:bundle && pnpm build:types",
    "build:bundle": "vite build",
    "build:types": "vue-tsc --project tsconfig.build.json && tsc-alias --project tsconfig.build.json",
    "preview": "vite preview",
    "release:check": "pnpm build && pnpm test:unit && npm pack --dry-run",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts --coverage",
    "test:integration": "if [ -z \"${DOCKER_HOST:-}\" ] && [ -S \"$HOME/.colima/docker.sock\" ]; then export DOCKER_HOST=\"unix://$HOME/.colima/docker.sock\"; export TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=\"${TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE:-/var/run/docker.sock}\"; fi; vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "db:up": "docker compose up -d influxdb",
    "db:down": "docker compose down -v",
    "db:seed": "tsx scripts/seed-influx.mts",
    "prepublishOnly": "pnpm release:check"
  },
  "keywords": [
    "influxdb",
    "vue",
    "vue3",
    "flux",
    "naive-ui",
    "echarts",
    "timeseries",
    "dashboard"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@influxdata/influxdb-client-browser": "^1.35.0",
    "@lezer/highlight": "^1.2.3",
    "@vicons/ionicons5": "^0.13.0",
    "apache-arrow": "^21.1.0",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "naive-ui": "^2.44.1",
    "parquet-wasm": "^0.7.1",
    "vue-echarts": "^8.0.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "happy-dom": "^20.8.8",
    "prettier": "^3.8.1",
    "testcontainers": "^11.13.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.1",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.5"
  }
}
